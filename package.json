{
  "name": "@formkit/drag-and-drop",
  "version": "0.5.3",
  "private": true,
  "description": "Drag and drop package.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "type": "module",
  "scripts": {
    "tests": "cd tests && pnpm run dev",
    "tests-frameworks": "cd tests-frameworks && pnpm run dev",
    "docs": "cd docs && pnpm run dev",
    "build": "jiti build.ts",
    "release": "npx bumpp && git push --follow-tags",
    "lint": "eslint ."
  },
  "packages": [],
  "keywords": [],
  "author": "Sasha Milenkovic <sasha@formkit.com>",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.51.1",
    "@types/react": "^18.3.20",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "bumpp": "^9.11.1",
    "esbuild-plugin-replace": "^1.4.0",
    "eslint": "^8.57.1",
    "eslint-plugin-vue": "^9.33.0",
    "jiti": "^2.4.2",
    "pathe": "^1.1.2",
    "publint": "^0.2.12",
    "tailwind": "^4.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3"
  },
  "exports": {
    "./vue": {
      "types": "./src/vue/index.ts",
      "default": "./src/vue/index.ts"
    },
    "./react": {
      "types": "./src/react/index.ts",
      "default": "./src/react/index.ts"
    },
    "./solid": {
      "types": "./src/solid/index.ts",
      "default": "./src/solid/index.ts"
    },
    "./marko": {
      "import": "./tags/dnd.marko",
      "default": "./tags/dnd.marko"
    },
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  }
}
