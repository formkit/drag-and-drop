{
  "name": "@formkit/drag-and-drop",
  "version": "0.5.3",
  "private": true,
  "description": "Drag and drop package.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "type": "module",
  "scripts": {
    "tests": "cd tests && pnpm run dev",
    "tests-frameworks": "cd tests-frameworks && pnpm run dev",
    "docs": "cd docs && pnpm run dev",
    "build": "jiti build.ts",
    "release": "npx bumpp && git push --follow-tags",
    "lint": "eslint ."
  },
  "packages": [],
  "keywords": [],
  "author": "Sasha Milenkovic <sasha@formkit.com>",
  "license": "MIT",
  "homepage": "https://drag-and-drop.formkit.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/formkit/drag-and-drop.git"
  },
  "bugs": {
    "url": "https://github.com/formkit/drag-and-drop/issues"
  },
  "peerDependencies": {
    "@marko/runtime-tags": ">=6.0.166"
  },
  "peerDependenciesMeta": {
    "@marko/runtime-tags": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@types/react": "^19.2.14",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "bumpp": "^11.0.1",
    "esbuild-plugin-replace": "^1.4.0",
    "eslint": "^10.2.1",
    "eslint-plugin-vue": "^10.9.0",
    "jiti": "^2.6.1",
    "pathe": "^2.0.3",
    "publint": "^0.3.18",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vue-eslint-parser": "^10.4.0"
  },
  "exports": {
    "./vue": {
      "types": "./src/vue/index.ts",
      "default": "./src/vue/index.ts"
    },
    "./react": {
      "types": "./src/react/index.ts",
      "default": "./src/react/index.ts"
    },
    "./solid": {
      "types": "./src/solid/index.ts",
      "default": "./src/solid/index.ts"
    },
    "./marko": {
      "import": "./src/marko/dnd.marko",
      "default": "./src/marko/dnd.marko"
    },
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  }
}
